<?xml version="1.0" encoding="utf-8"?>
    <androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.me.college.CollegeActivity">
    <!--TODO: 使用 MotionLayout 优化 -->

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/main_color">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsing_toolbar"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:layout_scrollFlags="scroll|exitUntilCollapsed"
                app:titleEnabled="false"
                app:contentScrim="@color/main_color">

                <!-- 展开时的垂直大布局 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_expanded"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="?attr/actionBarSize"
                    app:layout_collapseMode="parallax"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:id="@+id/iv_avatar_expanded"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher_round"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tv_username_expanded" />

                    <TextView
                        android:id="@+id/tv_username_expanded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="July"
                        app:layout_constraintTop_toBottomOf="@id/iv_avatar_expanded"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/tv_id_expanded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E0FFFFFF"
                        android:textSize="13sp"
                        tools:text="ID:20223"
                        app:layout_constraintTop_toBottomOf="@id/tv_username_expanded"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tv_score_expanded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E0FFFFFF"
                        android:textSize="13sp"
                        tools:text="积分：1000  排名：1"
                        app:layout_constraintTop_toBottomOf="@id/tv_id_expanded"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="4dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Toolbar -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    app:layout_collapseMode="pin"
                    app:navigationIcon="@drawable/baseline_chevron_white_left_24"
                    app:contentInsetStartWithNavigation="0dp"
                    app:contentInsetStart="0dp">

                    <!-- 折叠后显示在 Navigation 按钮右边的水平布局 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_collapsed"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:alpha="0">

                        <ImageView
                            android:id="@+id/iv_avatar_collapsed"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher_round"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:id="@+id/tv_username_collapsed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="July"
                            app:layout_constraintStart_toEndOf="@id/iv_avatar_collapsed"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginStart="10dp" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.appcompat.widget.Toolbar>

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- 列表区域 -->
        <com.study.wanandroid.ui.widget.StateLayout
            android:id="@+id/state_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.scwang.smart.refresh.layout.SmartRefreshLayout
                android:id="@+id/smart_refresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:srlEnableRefresh="false"
                app:srlEnableNestedScrolling="true">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycle_college"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/bg_gray"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="true" />

                <com.scwang.smart.refresh.footer.ClassicsFooter
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.scwang.smart.refresh.layout.SmartRefreshLayout>
        </com.study.wanandroid.ui.widget.StateLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>